<Window x:Class="RblxExecutorUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        Title="Senator Executor" Height="600" Width="980"
        Background="Transparent" Foreground="#C7CEDB"
        WindowStyle="None" AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI, Inter, sans-serif">

    <Window.Resources>
        <!-- ===== PALETTE: dark cyber ===== -->
        <SolidColorBrush x:Key="BgVoid"     Color="#050608"/>
        <SolidColorBrush x:Key="BgMain"     Color="#07090C"/>
        <SolidColorBrush x:Key="BgPanel"    Color="#0A0D12"/>
        <SolidColorBrush x:Key="BgSidebar"  Color="#06080B"/>
        <SolidColorBrush x:Key="BgCard"     Color="#0C0F15"/>
        <SolidColorBrush x:Key="BgCardHi"   Color="#11151D"/>
        <SolidColorBrush x:Key="LineDim"    Color="#13171F"/>
        <SolidColorBrush x:Key="LineMid"    Color="#1B2230"/>

        <SolidColorBrush x:Key="TextDim"    Color="#4A5161"/>
        <SolidColorBrush x:Key="TextMute"   Color="#6E7689"/>
        <SolidColorBrush x:Key="TextBase"   Color="#C7CEDB"/>
        <SolidColorBrush x:Key="TextHi"     Color="#E8ECF3"/>

        <SolidColorBrush x:Key="Cyan"       Color="#00E5FF"/>
        <SolidColorBrush x:Key="CyanDim"    Color="#0A8FA6"/>
        <SolidColorBrush x:Key="Lime"       Color="#B6FF3D"/>
        <SolidColorBrush x:Key="Magenta"    Color="#FF3D7F"/>
        <SolidColorBrush x:Key="Amber"      Color="#FFB347"/>

        <DropShadowEffect x:Key="GlowCyan"    BlurRadius="14" Color="#00E5FF" Opacity="0.65" ShadowDepth="0"/>
        <DropShadowEffect x:Key="GlowCyanSm"  BlurRadius="6"  Color="#00E5FF" Opacity="0.55" ShadowDepth="0"/>
        <DropShadowEffect x:Key="GlowLime"    BlurRadius="8"  Color="#B6FF3D" Opacity="0.6"  ShadowDepth="0"/>
        <DropShadowEffect x:Key="GlowMagenta" BlurRadius="8"  Color="#FF3D7F" Opacity="0.55" ShadowDepth="0"/>

        <!-- ===== SCROLLBAR ===== -->
        <Style x:Key="MyScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="#1F2735"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border Background="{TemplateBinding Background}" CornerRadius="0" Margin="3,2"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource Cyan}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource MyScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== SIDEBAR TAB ===== -->
        <Style x:Key="SidebarTab" TargetType="RadioButton">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Width"  Value="44"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#3F4658"/>
            <Setter Property="GroupName" Value="SidebarGroup"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="indicator"
                                    Width="2" Height="22"
                                    Background="{StaticResource Cyan}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Opacity="0">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" Color="#00E5FF" Opacity="0.85" ShadowDepth="0"/>
                                </Border.Effect>
                            </Border>
                            <Border x:Name="bg" Background="Transparent" CornerRadius="2" Margin="6,0,6,0">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#7E879A"/>
                                <Setter TargetName="bg" Property="Background" Value="#0E141C"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="indicator" Property="Opacity" Value="1"/>
                                <Setter Property="Foreground" Value="{StaticResource Cyan}"/>
                                <Setter TargetName="bg" Property="Background" Value="#0B1218"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ===== ICON BUTTONS ===== -->
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent" BorderThickness="1"
                                CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"  Value="#0F141B"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#1B2230"/>
                                <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0A0E14"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlayBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Foreground" Value="{StaticResource Cyan}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect" Value="{StaticResource GlowCyanSm}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource IconBtn}">
            <Setter Property="Foreground" Value="{StaticResource Magenta}"/>
        </Style>

        <Style x:Key="WindowBtn" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMute}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}" CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#11151D"/>
                                <Setter Property="Foreground" Value="{StaticResource TextHi}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WindowBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ===== CARDS ===== -->
        <Style x:Key="ScriptCard" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgCard}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource LineMid}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="2"/>
            <Setter Property="Padding"         Value="16,14"/>
            <Setter Property="Margin"          Value="6"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource Cyan}"/>
                    <Setter Property="Background"  Value="{StaticResource BgCardHi}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ClientCard" TargetType="Border" BasedOn="{StaticResource ScriptCard}">
            <Setter Property="Padding" Value="24"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource BgVoid}" BorderBrush="{StaticResource LineMid}" BorderThickness="1" CornerRadius="2" ClipToBounds="True" MouseLeftButtonDown="TitleBar_MouseDown">
        <Grid>
            <!-- Subtle dot grid background -->
            <Rectangle IsHitTestVisible="False" Opacity="0.18">
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile" Viewport="0,0,24,24" ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <GeometryDrawing Brush="#0F2A33">
                                <GeometryDrawing.Geometry>
                                    <EllipseGeometry RadiusX="0.7" RadiusY="0.7" Center="12,12"/>
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- Window control buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Panel.ZIndex="20">
                <Button Style="{StaticResource WindowBtn}" Click="Minimize_Click" Content="&#x2014;"/>
                <Button Style="{StaticResource CloseBtn}"  Click="Close_Click"    Content="&#x2715;"/>
            </StackPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="64"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Background="{StaticResource BgSidebar}" BorderBrush="{StaticResource LineMid}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Brand mark -->
                        <Border Grid.Row="0" Width="44" Height="44" Margin="0,18,0,18"
                                Background="#06090E" BorderBrush="{StaticResource Cyan}" BorderThickness="1" CornerRadius="2">
                            <Border.Effect><StaticResource ResourceKey="GlowCyanSm"/></Border.Effect>
                            <TextBlock Text="S" FontFamily="Consolas, Courier New, monospace" FontWeight="Black"
                                       FontSize="20" Foreground="{StaticResource Cyan}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>

                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Top">
                            <RadioButton Style="{StaticResource SidebarTab}" IsChecked="True" Checked="Tab_Editor" ToolTip="Editor">
                                <Path Data="M 4,16 L 12,8 L 4,0 M 14,16 L 20,16" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18"/>
                            </RadioButton>
                            <RadioButton Style="{StaticResource SidebarTab}" Checked="Tab_ScriptHub" ToolTip="Script Hub">
                                <Path Data="M 2,4 L 14,4 M 2,8 L 14,8 M 2,12 L 14,12" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="2" Stretch="Uniform" Width="18" Height="18"/>
                            </RadioButton>
                            <RadioButton Style="{StaticResource SidebarTab}" Checked="Tab_Clients" ToolTip="Clients">
                                <Path Data="M 8,8 A 4,4 0 1,0 8,0 A 4,4 0 1,0 8,8 Z M 0,16 C 0,10 16,10 16,16" Fill="Transparent" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.6" Stretch="Uniform" Width="18" Height="18"/>
                            </RadioButton>
                        </StackPanel>

                        <RadioButton Grid.Row="2" Style="{StaticResource SidebarTab}" Margin="0,0,0,18" Checked="Tab_Settings" ToolTip="Settings">
                            <Path Data="M 8,5 A 3,3 0 1,0 8.01,5 Z M 8,1 L 8,3 M 8,13 L 8,15 M 1,8 L 3,8 M 13,8 L 15,8 M 3.2,3.2 L 4.6,4.6 M 11.4,11.4 L 12.8,12.8 M 3.2,12.8 L 4.6,11.4 M 11.4,4.6 L 12.8,3.2"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" StrokeThickness="1.4"
                                  Stretch="Uniform" Width="18" Height="18" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </RadioButton>
                    </Grid>
                </Border>

                <!-- Right side -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="34"/>
                    </Grid.RowDefinitions>

                    <!-- ============ EDITOR ============ -->
                    <Grid x:Name="ViewEditor" Grid.Row="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="56"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header bar -->
                        <Border Grid.Row="0" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource LineMid}" BorderThickness="0,0,0,1">
                            <Grid Margin="22,0,80,0">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="SENATOR" FontFamily="Consolas, Courier New, monospace"
                                               FontWeight="Black" FontSize="14" Foreground="{StaticResource TextHi}"
                                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Border Background="#0B1218" BorderBrush="{StaticResource CyanDim}" BorderThickness="1" CornerRadius="2"
                                            Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock Text="v1.0" FontFamily="Consolas, Courier New, monospace"
                                                   FontSize="10" Foreground="{StaticResource Cyan}"/>
                                    </Border>
                                    <TextBlock Text="// EDITOR" FontFamily="Consolas, Courier New, monospace"
                                               FontSize="11" Foreground="{StaticResource TextDim}"
                                               VerticalAlignment="Center" Margin="14,0,0,0"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right">
                                    <Button Style="{StaticResource PlayBtn}" Click="Execute_Click" ToolTip="Execute Script">
                                        <Path Data="M 2,0 L 12,7 L 2,14 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="11" Height="11"/>
                                    </Button>
                                    <Button Style="{StaticResource IconBtn}" Margin="4,0,0,0" Click="Clear_Click" ToolTip="Clear Editor">
                                        <Path Data="M 2,14 L 6,14 L 14,6 L 10,2 L 2,10 Z M 10,2 L 14,6" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="13" Height="13"/>
                                    </Button>

                                    <Border Width="1" Height="16" Background="{StaticResource LineMid}" Margin="10,0"/>

                                    <Button Style="{StaticResource IconBtn}" Click="Save_Click" ToolTip="Save File">
                                        <Path Data="M 2,2 L 14,2 L 14,14 L 2,14 Z M 5,2 L 5,6 L 11,6 L 11,2 M 4,14 L 4,9 L 12,9 L 12,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="13" Height="13"/>
                                    </Button>
                                    <Button Style="{StaticResource IconBtn}" Margin="4,0,0,0" Click="Open_Click" ToolTip="Open Folder">
                                        <Path Data="M 1,4 L 6,4 L 8,6 L 15,6 L 15,13 L 1,13 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="13" Height="13"/>
                                    </Button>

                                    <Border Width="1" Height="16" Background="{StaticResource LineMid}" Margin="10,0"/>

                                    <Button Style="{StaticResource DangerBtn}" Click="KillRoblox_Click" ToolTip="Kill Roblox Process">
                                        <Path Data="M 2,2 L 14,14 M 14,2 L 2,14" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="2" Stretch="Uniform" Width="11" Height="11" StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Code editor -->
                        <Border Grid.Row="1" Background="{StaticResource BgMain}">
                            <avalonEdit:TextEditor Name="Editor"
                                                   FontFamily="Consolas, Courier New, monospace" FontSize="13"
                                                   Background="Transparent" Foreground="{StaticResource TextHi}"
                                                   ShowLineNumbers="True" LineNumbersForeground="#2A3343"
                                                   Margin="0" Padding="8,12,12,12"/>
                        </Border>
                    </Grid>

                    <!-- ============ SCRIPT HUB ============ -->
                    <Grid x:Name="ViewScriptHub" Grid.Row="0" Visibility="Collapsed">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="32,32,32,8">
                                    <TextBlock Text="SCRIPT HUB" FontFamily="Consolas, Courier New, monospace"
                                               Foreground="{StaticResource TextHi}" FontSize="20" FontWeight="Black"/>
                                    <Border Background="Transparent" BorderBrush="{StaticResource LineMid}" BorderThickness="0,0,0,1"
                                            VerticalAlignment="Bottom" Margin="14,0,0,4" Width="200" Height="1"/>
                                </StackPanel>
                                <TextBlock Text="// LOCAL .lua / .luau / .txt FILES IN ./Scripts" FontFamily="Consolas, Courier New, monospace"
                                           Foreground="{StaticResource TextDim}" FontSize="11" Margin="32,0,0,18"/>

                                <ItemsControl x:Name="ScriptHubList" Margin="22,0,22,32">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource ScriptCard}">
                                                <Grid>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <Path Data="M 2,2 L 10,2 L 14,6 L 14,14 L 2,14 Z M 10,2 L 10,6 L 14,6"
                                                              Stroke="{StaticResource Cyan}" StrokeThickness="1.4"
                                                              Stretch="Uniform" Width="14" Height="14" Margin="0,0,12,0"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextHi}"
                                                                   FontSize="13" FontWeight="SemiBold"
                                                                   FontFamily="Consolas, Courier New, monospace"/>
                                                    </StackPanel>
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                        <Button Style="{StaticResource PlayBtn}" Click="ExecuteScriptHub_Click" Tag="{Binding FullPath}" ToolTip="Run">
                                                            <Path Data="M 2,0 L 12,7 L 2,14 Z" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Width="10" Height="10"/>
                                                        </Button>
                                                        <Button Style="{StaticResource IconBtn}" Margin="2,0,0,0" Click="CopyScriptHub_Click" Tag="{Binding FullPath}" ToolTip="Copy">
                                                            <Path Data="M 4,4 L 10,4 L 10,12 L 4,12 Z M 6,2 L 12,2 L 12,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="11" Height="11"/>
                                                        </Button>
                                                        <Button Style="{StaticResource DangerBtn}" Margin="2,0,0,0" Click="DeleteScriptHub_Click" Tag="{Binding FullPath}" ToolTip="Delete">
                                                            <Path Data="M 3,4 L 13,4 M 6,4 L 6,2 L 10,2 L 10,4 M 4,4 L 4,14 L 12,14 L 12,4" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.5" Stretch="Uniform" Width="11" Height="11"/>
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- ============ CLIENTS ============ -->
                    <Grid x:Name="ViewClients" Grid.Row="0" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="32,32,32,8">
                                <TextBlock Text="CLIENT" FontFamily="Consolas, Courier New, monospace"
                                           Foreground="{StaticResource TextHi}" FontSize="20" FontWeight="Black"/>
                                <Border Background="Transparent" BorderBrush="{StaticResource LineMid}" BorderThickness="0,0,0,1"
                                        VerticalAlignment="Bottom" Margin="14,0,0,4" Width="240" Height="1"/>
                            </StackPanel>
                            <TextBlock Text="// ACTIVE ROBLOX CLIENT INFO" FontFamily="Consolas, Courier New, monospace"
                                       Foreground="{StaticResource TextDim}" FontSize="11" Margin="32,0,0,18"/>

                            <Border Style="{StaticResource ClientCard}" Width="320" HorizontalAlignment="Left" Margin="32,4,0,0">
                                <StackPanel>
                                    <Border Width="78" Height="78" CornerRadius="2" Background="#0B1218"
                                            BorderBrush="{StaticResource Cyan}" BorderThickness="1"
                                            Margin="0,0,0,18" ClipToBounds="True">
                                        <Border.Effect><StaticResource ResourceKey="GlowCyanSm"/></Border.Effect>
                                        <Image x:Name="ClientAvatarImage" Stretch="UniformToFill"/>
                                    </Border>
                                    <TextBlock x:Name="ClientAccountName" Text="Not Connected"
                                               FontFamily="Consolas, Courier New, monospace"
                                               TextAlignment="Center" FontSize="16" Foreground="{StaticResource TextHi}"
                                               FontWeight="Bold"/>
                                    <TextBlock x:Name="ClientPidText" Text="PID: None | Place: None"
                                               FontFamily="Consolas, Courier New, monospace"
                                               TextAlignment="Center" FontSize="11" Foreground="{StaticResource TextMute}"
                                               Margin="0,6,0,16"/>

                                    <Border Name="ClientBadgeBg"
                                            Background="#0A0E14" BorderThickness="1" BorderBrush="{StaticResource LineMid}"
                                            CornerRadius="2" Padding="14,5"
                                            HorizontalAlignment="Center">
                                        <TextBlock x:Name="ClientStatusBadge" Text="READY"
                                                   FontFamily="Consolas, Courier New, monospace"
                                                   FontSize="10" FontWeight="Bold" Foreground="{StaticResource TextMute}"/>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ============ SETTINGS ============ -->
                    <Grid x:Name="ViewSettings" Grid.Row="0" Visibility="Collapsed">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="32,32,32,8">
                                <TextBlock Text="CONFIG" FontFamily="Consolas, Courier New, monospace"
                                           Foreground="{StaticResource TextHi}" FontSize="20" FontWeight="Black"/>
                                <Border Background="Transparent" BorderBrush="{StaticResource LineMid}" BorderThickness="0,0,0,1"
                                        VerticalAlignment="Bottom" Margin="14,0,0,4" Width="240" Height="1"/>
                            </StackPanel>
                            <TextBlock Text="// RUNTIME OPTIONS" FontFamily="Consolas, Courier New, monospace"
                                       Foreground="{StaticResource TextDim}" FontSize="11" Margin="32,0,0,18"/>

                            <Border Background="{StaticResource BgCard}" BorderBrush="{StaticResource LineMid}" BorderThickness="1"
                                    CornerRadius="2" Margin="32,0,32,0" Padding="22">
                                <StackPanel>
                                    <TextBlock Text="DEVELOPER CONTROLS" FontFamily="Consolas, Courier New, monospace"
                                               Foreground="{StaticResource Cyan}" FontWeight="Bold" FontSize="11"
                                               Margin="0,0,0,16"/>

                                    <CheckBox IsChecked="False" Checked="ToggleConsole_Checked" Unchecked="ToggleConsole_Unchecked" Cursor="Hand">
                                        <CheckBox.Template>
                                            <ControlTemplate TargetType="CheckBox">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <Border x:Name="track" Width="38" Height="20" CornerRadius="1"
                                                            Background="#0A0E14" BorderBrush="{StaticResource LineMid}" BorderThickness="1">
                                                        <Border x:Name="thumb" Width="14" Height="14" CornerRadius="1"
                                                                Background="#3F4658" HorizontalAlignment="Left" Margin="2,0,0,0"
                                                                VerticalAlignment="Center">
                                                            <Border.RenderTransform>
                                                                <TranslateTransform X="0"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                    </Border>
                                                    <TextBlock Text="Debug Console" Foreground="{StaticResource TextBase}"
                                                               FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"
                                                               FontFamily="Consolas, Courier New, monospace"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter TargetName="track" Property="Background" Value="#062029"/>
                                                        <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource Cyan}"/>
                                                        <Setter TargetName="thumb" Property="Background" Value="{StaticResource Cyan}"/>
                                                        <Setter TargetName="thumb" Property="RenderTransform">
                                                            <Setter.Value>
                                                                <TranslateTransform X="18"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter TargetName="thumb" Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="6" Color="#00E5FF" Opacity="0.65" ShadowDepth="0"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource CyanDim}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </CheckBox.Template>
                                    </CheckBox>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- ============ STATUS BAR ============ -->
                    <Border Grid.Row="1" Background="{StaticResource BgPanel}" BorderBrush="{StaticResource LineMid}" BorderThickness="0,1,0,0" Padding="18,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="6" Height="6" Margin="0,0,8,0" Fill="{StaticResource Cyan}">
                                    <Ellipse.Effect>
                                        <DropShadowEffect BlurRadius="6" Color="#00E5FF" Opacity="0.85" ShadowDepth="0"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                                <TextBlock x:Name="InjectionStatus" Text="IDLE"
                                           FontFamily="Consolas, Courier New, monospace"
                                           Foreground="{StaticResource TextMute}" FontSize="10"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <Border Width="1" Height="14" Background="{StaticResource LineMid}" Margin="14,0"/>
                                <TextBlock Text="senator://core" FontFamily="Consolas, Courier New, monospace"
                                           FontSize="10" Foreground="{StaticResource TextDim}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right" Style="{StaticResource PlayBtn}" Click="Attach_Click" ToolTip="Attach to Roblox">
                                <Path Data="M 10,2 L 10,6 L 14,6 L 14,10 M 6,14 L 6,10 L 2,10 L 2,6 M 10,6 L 6,10"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.6" Stretch="Uniform" Width="12" Height="12"
                                      StrokeEndLineCap="Round" StrokeStartLineCap="Round"/>
                            </Button>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- ============ NOTIFICATION ============ -->
            <Canvas HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,22,46" Panel.ZIndex="100">
                <Border x:Name="NotificationBox"
                        Background="{StaticResource BgPanel}" BorderBrush="{StaticResource Cyan}" BorderThickness="1"
                        CornerRadius="2" Padding="18,12" MinWidth="220" Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="3" Opacity="0.5"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <Path x:Name="NotificationIcon"
                              Data="M 8,2 A 6,6 0 1 1 7.9,2.1 Z M 6,8 L 8,10 L 12,5"
                              Stroke="{StaticResource Cyan}" StrokeThickness="1.8"
                              Stretch="Uniform" Width="14" Height="14"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBlock x:Name="NotificationText" Text="Notification"
                                   Foreground="{StaticResource TextHi}"
                                   FontFamily="Consolas, Courier New, monospace"
                                   FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Canvas>
        </Grid>
    </Border>
</Window>
